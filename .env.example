# ============================================================
# PharmaERP - Frontend Environment Configuration (Local Development)
# ============================================================
# Copy this file to .env and update with your local values
# cp .env.example .env

# ─────────────────────────────────────────────────────────────
# API Configuration
# ─────────────────────────────────────────────────────────────
# Backend API URL (used by Vite proxy in development)
VITE_API_URL=https://pharmabackend-g4ebfeegh9gthwgr.centralindia-01.azurewebsites.net

# ─────────────────────────────────────────────────────────────
# Application Settings
# ─────────────────────────────────────────────────────────────
VITE_APP_NAME=PharmaERP
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# ─────────────────────────────────────────────────────────────
# Feature Flags (Optional)
# ─────────────────────────────────────────────────────────────
# VITE_FEATURE_DARK_MODE=true
# VITE_FEATURE_NOTIFICATIONS=true
# VITE_FEATURE_ANALYTICS=false

# ─────────────────────────────────────────────────────────────
# Print Configuration
# ─────────────────────────────────────────────────────────────
# VITE_PRINT_ENABLED=true
# VITE_PRINT_DEFAULT_WIDTH=80mm

# ─────────────────────────────────────────────────────────────
# Pagination Defaults
# ─────────────────────────────────────────────────────────────
# VITE_DEFAULT_PAGE_SIZE=100
# VITE_INVOICE_PAGE_SIZE=50

# ─────────────────────────────────────────────────────────────
# Timeout Configuration (milliseconds)
# ─────────────────────────────────────────────────────────────
# VITE_API_TIMEOUT=30000
# VITE_UPLOAD_TIMEOUT=60000

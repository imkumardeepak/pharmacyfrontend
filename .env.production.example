# ============================================================
# PharmaERP - Frontend Environment Configuration (Production)
# ============================================================
# NEVER commit this file to version control!
# Add to .gitignore: frontend/.env.production.local

# ─────────────────────────────────────────────────────────────
# API Configuration (Production)
# ─────────────────────────────────────────────────────────────
# Backend API URL (your production API endpoint)
VITE_API_URL=https://pharmabackend-g4ebfeegh9gthwgr.centralindia-01.azurewebsites.net

# ─────────────────────────────────────────────────────────────
# Application Settings (Production)
# ─────────────────────────────────────────────────────────────
VITE_APP_NAME=PharmaERP
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=production

# ─────────────────────────────────────────────────────────────
# Feature Flags (Production)
# ─────────────────────────────────────────────────────────────
VITE_FEATURE_DARK_MODE=true
VITE_FEATURE_NOTIFICATIONS=true
VITE_FEATURE_ANALYTICS=true

# ─────────────────────────────────────────────────────────────
# Analytics Configuration (Optional)
# ─────────────────────────────────────────────────────────────
# VITE_ANALYTICS_ID=UA-XXXXXXXXX-X
# VITE_ANALYTICS_ENABLED=true

# ─────────────────────────────────────────────────────────────
# Print Configuration (Production)
# ─────────────────────────────────────────────────────────────
VITE_PRINT_ENABLED=true
VITE_PRINT_DEFAULT_WIDTH=80mm

# ─────────────────────────────────────────────────────────────
# Pagination Defaults (Production)
# ─────────────────────────────────────────────────────────────
VITE_DEFAULT_PAGE_SIZE=100
VITE_INVOICE_PAGE_SIZE=50

# ─────────────────────────────────────────────────────────────
# Timeout Configuration (Production - milliseconds)
# ─────────────────────────────────────────────────────────────
VITE_API_TIMEOUT=30000
VITE_UPLOAD_TIMEOUT=60000

# ─────────────────────────────────────────────────────────────
# CDN Configuration (Optional)
# ─────────────────────────────────────────────────────────────
# VITE_CDN_URL=https://cdn.pharmaerp.yourdomain.com

# ─────────────────────────────────────────────────────────────
# Sentry Error Tracking (Optional)
# ─────────────────────────────────────────────────────────────
# VITE_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
# VITE_SENTRY_ENABLED=true
